# ==============================================================================
# EduNaukri — Developer Reference Template
# Usage: copy .env.example .env  then fill in the blanks.
# This file MUST NOT contain real secrets. It is committed to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Django Core
# ------------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-dev-only-change-for-production-min-50-chars!!
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ------------------------------------------------------------------------------
# Database (PostgreSQL — used in Docker / production)
# Development falls back to SQLite automatically via config.settings.development
# ------------------------------------------------------------------------------
DB_NAME=edunaukri
DB_USER=edunaukri
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432
DB_SSL=False

# ------------------------------------------------------------------------------
# Redis & Celery
# Use redis://redis:6379/N inside Docker Compose, redis://127.0.0.1:6379/N locally
# ------------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ------------------------------------------------------------------------------
# SMTP Email
# Development uses the console backend — these only matter in production
# ------------------------------------------------------------------------------
AUTH_EMAIL_DELIVERY_ENABLED=False
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=EduNaukri <noreply@edunaukri.com>
AUTH_EMAIL_FROM=EduNaukri <noreply@edunaukri.com>

# ------------------------------------------------------------------------------
# OAuth — Google & LinkedIn
# ------------------------------------------------------------------------------
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# URL Bases
# ------------------------------------------------------------------------------
AUTH_FRONTEND_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------
STORAGE_BACKEND=local
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# ------------------------------------------------------------------------------
# JWT & Cookie Security
# ------------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

# ------------------------------------------------------------------------------
# Session Security
# ------------------------------------------------------------------------------
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_AGE=28800

# ------------------------------------------------------------------------------
# Authentication Behaviour
# ------------------------------------------------------------------------------
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=30
AUTH_REQUIRE_EMAIL_VERIFICATION=False

# ------------------------------------------------------------------------------
# CORS (SPA / frontend — development defaults are set automatically in base.py)
# ------------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# ------------------------------------------------------------------------------
# Admin & API
# ------------------------------------------------------------------------------
ADMIN_URL=admin/
ENABLE_API_DOCS=True
RATELIMIT_ENABLE=True

# ------------------------------------------------------------------------------
# Timezone
# ------------------------------------------------------------------------------
TIME_ZONE=Asia/Kolkata

# ------------------------------------------------------------------------------
# Docker Compose — pgAdmin UI (internal tooling, not used by Django)
# ------------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@edunaukri.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# ------------------------------------------------------------------------------
# Docker Compose — Backup Service (internal tooling, not used by Django)
# ------------------------------------------------------------------------------
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=5
RESTORE_TEST_ENABLED=true
