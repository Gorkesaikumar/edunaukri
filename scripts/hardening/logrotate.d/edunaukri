# ==========================================
# EduNaukri Master Log Rotation Configuration
# ==========================================

/backups/logs/*.log
/var/log/nginx/*.log
/var/log/edunaukri/*.log
{
    daily
    missingok
    rotate 30
    compress
    delaycompress
    notifempty
    copytruncate
    dateext
    create 0640 root adm
}
